# GitHub personal access token with `issues:read` scope.
GITHUB_TOKEN=

# OpenAI API key used for embeddings.
OPENAI_API_KEY=

# Optional: override the OpenAI base URL (e.g. Azure, OpenAI-compatible proxy).
# OpenRouter does not support OpenAI's embeddings endpoint; use real OpenAI keys
# or another compatible embeddings provider.
# OPENAI_BASE_URL=

# Target repo in `owner/repo` form.
GITHUB_REPO=wailsapp/wails
